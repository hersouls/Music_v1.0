# ─────────────────────────────────────────────
# Moonwave Music — 환경변수
# 이 파일을 .env.local 로 복사한 뒤 값을 채우고 개발 서버를 재시작하세요.
#   Copy-Item .env.example .env.local
# .env.local 은 git 에 올라가지 않습니다.
# ─────────────────────────────────────────────

# ── Firebase 웹 설정 (공유 버전 필수) ──
# Firebase 콘솔 > 프로젝트 설정 > 내 앱(웹) 에서 확인.
# ⚠️ Health 와 별도의 새 Firebase 프로젝트를 쓰세요.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# 사이트 URL (선택)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI 자동 가사 싱크 (선택, 서버 전용) ──
# OpenAI Whisper 로 음원을 전사해 LRC 초안 생성. https://platform.openai.com/api-keys
# ⚠️ NEXT_PUBLIC_ 접두사 금지 (서버에서만 사용).
OPENAI_API_KEY=
